---
import Layout from "../layouts/Layout.astro";
const pageTitle = "Emme portfolio";
import { getCollection } from "astro:content";
import { data } from "../content/data";
import { Image } from "astro:assets";
import Reveal from "../components/Reveal.jsx";

import About from "./about.astro";
import Works from "./works.astro";
import Contact from "./contact.astro";

const allProjects = await getCollection("projects");
const artsEntries = await getCollection("arts");

const imgArt = data.Works.Arts;
const imgEmote = data.Works.Emote;
---

<Layout pageTitle={pageTitle}>
  <!-- Home Section -->
   <br>
  <Reveal client:visible>
    <section class="hero-section">
      <div style="text-align: center;">
        <Image src="/material/emme-patata.png" alt="Emme patata icon" width={300} height={259} loading="lazy" id="emme-patata" />
      </div>
      <h1 class="display-5 fw-bold lh-1 mb-3 text-white">
        Ciao! <i class="fa-solid fa-music fa-bounce"></i>
        <br />
        I'm <b>Manuela</b>,
      </h1>
      <h2>a Front-end Developer, Digital 2D Artist and Twitch Streamer from Italy</h2>
      <p>
        I'm a creative chill person with the passion of learning new things while destroying them to understand how they work.<br />
        If you are curious to know more about me feel free to browse this portfolio to see my work and more!
      </p>
    </section>
  </Reveal>

  <!-- About Section -->
  <Reveal client:visible>
    <section id="about">
      <About />
    </section>
  </Reveal>

  <!-- Works Section -->
  <Reveal client:visible>
    <section id="works">
      <Works />
    </section>
  </Reveal>

  <!-- Contact Section -->
  <Reveal client:visible>
    <section id="contact">
      <Contact />
    </section>
  </Reveal>
</Layout>
