---
import { getCollection } from "astro:content";
import { data } from "../content/data"
import Card from '../components/Card.astro';
import SwiperArt from "../components/Swiper-Art.astro";
import SwiperGraphic from "../components/Swiper-Graphic.astro";

const allProjects = await getCollection("projects");
const imgArt = data.Works.Arts;
const imgEmote = data.Works.Emote;

console.log("Works - Projects length:", allProjects.length);
console.log("Works - Arts length:", imgArt.length);
console.log("Works - Emotes length:", imgEmote.length);

---
<div class="text"><h2>Code projects:</h2></div>

  {allProjects.length > 0 ? (
    <ul role="list" class="link-card-grid">
        {allProjects.map((card) => <Card 
            url={`/projects/${card.id}/`} 
            image={card.data.image.url} 
            title={card.data.title}
            body={card.data.description}
        />)}
    </ul>
  ) : (
    <p>Nessun progetto trovato - Controlla che le collezioni siano caricate</p>
  )}

  <div class="text" id="triggerSection"><h2>Arts projects:</h2></div>

