---
import { data } from "../content/data"

---
<br>
<h2>{data.Contact.Intro}</h2>
<div style="text-align: center;" class="contact">
  <p class="email-line">(っ ͡❛ ᴗ ͡❛)っ <a href="mailto:manuelaienuso@gmail.com">{data.Contact.Mail} <i class="fa-solid fa-envelope" style=" vertical-align: middle; display: inline-block; transform: rotate(8deg);"></i> </a></p>

   <div class="social-wrap">
        <span>Follow me here!</span>
        <div class="social-container">
          {
            data.Contact.Socials.map((social) => (
              <a href={social.link} target="_blank">
                <i class={social.icon} style="font-size: large; padding:10px;" />
              </a>
            ))
          }
        </div>
      </div>
      <br>
</div>

